{
  "name": "@visidiff/cli",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "visidiff": "./bin/visidiff.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "compare": "node bin/visidiff.js compare",
    "init": "node bin/visidiff.js init",
    "rescreenshot": "node bin/visidiff.js rescreenshot"
  },
  "dependencies": {
    "@visidiff/core": "workspace:*",
    "@visidiff/server": "workspace:*",
    "commander": "^11.1.0",
    "open": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
